df = pd.read_csv(io.StringIO(CSV_DATA))
df['PurchaseDate'] = pd.to_datetime(df['PurchaseDate'])

OUTPUT = "/mnt/user-data/outputs"
os.makedirs(OUTPUT, exist_ok=True)

# ── Q1: Data Exploration ──────────────────────────────────────────────────────
print("=" * 60)
print("Q1: DATA EXPLORATION")
print("=" * 60)
print("\nFirst 5 rows:")
print(df.head())
print("\nLast 5 rows:")
print(df.tail())
print(f"\nShape: {df.shape}")
print(f"\nColumns: {df.columns.tolist()}")
print("\nData Types:")
print(df.dtypes)

# ── Q2: Descriptive Statistics ────────────────────────────────────────────────
print("\n" + "=" * 60)
print("Q2: DESCRIPTIVE STATISTICS")
print("=" * 60)
print(f"Average Age            : {df['Age'].mean():.2f}")
print(f"Max Price              : ${df['Price'].max()}")
print(f"Min Price              : ${df['Price'].min()}")
print(f"Total Quantity Sold    : {df['Quantity'].sum()}")
print(f"Average Product Price  : ${df['Price'].mean():.2f}")
print("\nSummary Statistics:")
print(df.describe())

# ── Q3: Sales Calculation ─────────────────────────────────────────────────────
print("\n" + "=" * 60)
print("Q3: SALES CALCULATION")
print("=" * 60)
df['TotalAmount'] = df['Quantity'] * df['Price']
print(df[['Name', 'Product', 'Quantity', 'Price', 'TotalAmount']].to_string(index=False))
print(f"\nTotal Sales            : ${df['TotalAmount'].sum():,.2f}")
print(f"Highest Transaction    : ${df['TotalAmount'].max():,.2f}")
print(f"Lowest Transaction     : ${df['TotalAmount'].min():,.2f}")

# ── Q4: Customer Analysis ─────────────────────────────────────────────────────
print("\n" + "=" * 60)
print("Q4: CUSTOMER ANALYSIS")
print("=" * 60)
male_df   = df[df['Gender'] == 'Male']
female_df = df[df['Gender'] == 'Female']
print(f"Male customers         : {len(male_df)}")
print(f"Female customers       : {len(female_df)}")
print(f"Avg age (Male)         : {male_df['Age'].mean():.2f}")
print(f"Avg age (Female)       : {female_df['Age'].mean():.2f}")
male_spend   = male_df['TotalAmount'].sum()
female_spend = female_df['TotalAmount'].sum()
print(f"Total spend (Male)     : ${male_spend:,.2f}")
print(f"Total spend (Female)   : ${female_spend:,.2f}")
print(f"Higher spender gender  : {'Male' if male_spend > female_spend else 'Female'}")

# ── Q5: City-Based Analysis ───────────────────────────────────────────────────
print("\n" + "=" * 60)
print("Q5: CITY-BASED ANALYSIS")
print("=" * 60)
city_sales = df.groupby('City')['TotalAmount'].sum().sort_values(ascending=False)
print(city_sales.to_string())
print(f"\nCity with highest sales: {city_sales.idxmax()} (${city_sales.max():,.2f})")

fig, ax = plt.subplots(figsize=(8, 5))
city_sales.plot(kind='bar', ax=ax, color='steelblue', edgecolor='black')
ax.set_title("Sales by City")
ax.set_xlabel("City")
ax.set_ylabel("Total Sales ($)")
ax.tick_params(axis='x', rotation=45)
plt.tight_layout()
plt.savefig(f"{OUTPUT}/q15_sales_by_city.png", dpi=100)
plt.close()
print("  → Chart saved: q15_sales_by_city.png")
print("\nExplanation: Calgary dominates sales because it has the most customers "
      "in the dataset. Edmonton and Lethbridge follow. Smaller cities like "
      "Medicine Hat and Red Deer contribute the least, partly due to fewer customers.")

# ── Q6: Product Analysis ──────────────────────────────────────────────────────
print("\n" + "=" * 60)
print("Q6: PRODUCT ANALYSIS")
print("=" * 60)
cat_count      = df.groupby('Category')['Quantity'].sum()
