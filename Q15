# ── Q8: Advanced Analysis ─────────────────────────────────────────────────────
print("\n" + "=" * 60)
print("Q8: ADVANCED ANALYSIS")
print("=" * 60)
customer_spend = df.groupby('Name')['TotalAmount'].sum()
customer_qty   = df.groupby('Name')['Quantity'].sum()
print(f"Highest spending customer : {customer_spend.idxmax()} (${customer_spend.max():,.2f})")
print(f"Highest quantity customer : {customer_qty.idxmax()} ({customer_qty.max()} units)")

electronics = df[df['Category'] == 'Electronics']
city_elec   = electronics.groupby('City')['TotalAmount'].sum()
print(f"City with most electronics spending: {city_elec.idxmax()} (${city_elec.max():,.2f})")

def age_group(age):
    if 20 <= age <= 30:   return "20-30"
    elif 31 <= age <= 40: return "31-40"
    else:                 return "41-60"

df['AgeGroup'] = df['Age'].apply(age_group)
age_spend = df.groupby('AgeGroup')['TotalAmount'].sum().sort_values(ascending=False)
print(f"\nSpending by age group:")
print(age_spend.to_string())
print(f"Highest spending group: {age_spend.idxmax()}")

fig, axes = plt.subplots(1, 2, figsize=(12, 5))
customer_spend.sort_values().plot(kind='barh', ax=axes[0], color='mediumseagreen')
axes[0].set_title("Spending by Customer")
axes[0].set_xlabel("Total Amount ($)")

age_spend.plot(kind='bar', ax=axes[1], color='mediumpurple', edgecolor='black')
axes[1].set_title("Spending by Age Group")
axes[1].set_xlabel("Age Group")
axes[1].set_ylabel("Total Amount ($)")
axes[1].tick_params(axis='x', rotation=0)

plt.tight_layout()
plt.savefig(f"{OUTPUT}/q15_advanced.png", dpi=100)
plt.close()
print("  → Chart saved: q15_advanced.png")

# ── Q9: Missing Values Challenge ─────────────────────────────────────────────
print("\n" + "=" * 60)
print("Q9: MISSING VALUES CHALLENGE")
print("=" * 60)
df_missing = df.copy()
np.random.seed(0)

for col, idx in [('Age', 2), ('Price', 5), ('City', 8),
                 ('Quantity', 11), ('Product', 14)]:
    df_missing.loc[idx, col] = np.nan

print("Missing values after introduction:")
print(df_missing.isnull().sum()[df_missing.isnull().sum() > 0])

# Fill missing values
df_missing['Age']      = df_missing['Age'].fillna(df_missing['Age'].median())
df_missing['Price']    = df_missing['Price'].fillna(df_missing['Price'].mean())
df_missing['Quantity'] = df_missing['Quantity'].fillna(df_missing['Quantity'].median())
df_missing['City']     = df_missing['City'].fillna(df_missing['City'].mode()[0])
df_missing['Product']  = df_missing['Product'].fillna(df_missing['Product'].mode()[0])

print("\nMissing values after replacement:")
print(df_missing.isnull().sum())
print("Dataset is now clean — no missing values.")

