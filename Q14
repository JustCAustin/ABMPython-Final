if __name__ == "__main__":
    print("\n\n" + "="*55)
    print("  SMART PARKING MANAGEMENT SYSTEM")
    print("="*55)

    lot = ParkingLot("Downtown Parking")

    # Add spots
    for i in range(1, 4): lot.add_spot(f"C{i}", "Car")
    for i in range(1, 3): lot.add_spot(f"B{i}", "Bike")
    lot.add_spot("T1", "Truck")

    ParkingLot.daily_rate_info()
    lot.available_spots()

    print()
    lot.park_vehicle("ABC-123", "Car")
    lot.park_vehicle("XYZ-789", "Bike")
    lot.park_vehicle("TRK-001", "Truck")

    lot.available_spots()

    print()
    lot.exit_vehicle("C1")
    lot.exit_vehicle("B1")
    lot.exit_vehicle("T1")

    lot.revenue_report()
