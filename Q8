    doc1.treat(p1, "Hypertension",      "Amlodipine 5mg")
    doc2.treat(p1, "Migraine",          "Sumatriptan 50mg")
    doc1.treat(p2, "Arrhythmia",        "Metoprolol 25mg")

    p1.get_history()
    p2.get_history()

    # Encapsulation test — records cannot be altered directly
    rec = p1._records[0]
    try:
        rec.__diagnosis = "Hacked"
    except AttributeError as e:
        print(f"Encapsulation holds: {e}")
