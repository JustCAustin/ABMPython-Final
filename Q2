if __name__ == "__main__":
    t = Transaction(
        transaction_id="TXN-001",
        amount=1500.00,
        currency="CAD",
        sender="Alice",
        receiver="Bob",
        timestamp="2025-01-10 09:30:00"
    )

    print(t)
    print(repr(t))

    # Attempt modification
    print("\n--- Immutability Tests ---")
    try:
        t.amount = 9999
    except AttributeError as e:
        print(f"Modify test  : {e}")

    try:
        del t.sender
    except AttributeError as e:
        print(f"Delete test  : {e}")

    try:
        t.new_field = "hacked"
    except AttributeError as e:
        print(f"Add test     : {e}")

    # Subclass test
    print("\n--- International Transaction ---")
    it = InternationalTransaction(
        "TXN-002", 2000, "USD", "Charlie", "Diana",
        "2025-01-11 10:00:00", exchange_rate=1.36
    )
    print(it)

    try:
        it.exchange_rate = 1.99
    except AttributeError as e:
        print(f"Subclass immutability: {e}")
